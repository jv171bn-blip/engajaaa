{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/quiz/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "trailingSlash": false
}
